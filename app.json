{
  "expo": {
    "name": "pokedex",
    "slug": "pokedex",
    "version": "1.0.0",
    "scheme": "pokedex",

    "orientation": "portrait",
    "userInterfaceStyle": "light",

    "icon": "./assets/icon.png",

    "assetBundlePatterns": ["**/*"],

    "web": {
      "favicon": "./assets/favicon.png"
    },

    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yourname.pokedex"
    },

    "android": {
      "package": "com.yourname.pokedex",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      }
    },

    "experiments": {
      "tsconfigPaths": true
    },

    "plugins": []
  }
}
